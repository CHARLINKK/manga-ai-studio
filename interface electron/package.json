{
  "name": "manga-ai-studio",
  "private": true,
  "version": "2.0.6",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron . --dev",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.charlinkk.manga-ai-studio",
    "productName": "Manga AI Studio",
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [

      {
        "from": "../",
        "to": "backend",
        "filter": [
          "*.py",
          "requirements*.txt"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "CHARLINKK",
        "repo": "manga-ai-studio"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
